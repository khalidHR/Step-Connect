{
  "expo": {
    "name": "StepConnect",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMotionUsageDescription": "StepConnect uses your motion data to track your daily steps and compete with friends.",
        "NSHealthShareUsageDescription": "StepConnect reads your step count from Apple Health to power your leaderboard and reports.",
        "NSHealthUpdateUsageDescription": "StepConnect may write workout summaries to Apple Health."
      }
    },
    "android": {
      "permissions": ["android.permission.ACTIVITY_RECOGNITION"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
